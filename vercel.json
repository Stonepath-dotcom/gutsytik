{
  "functions": {
    "src/app/api/download/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/proxy/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/yt-edge/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/blog/generate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/refresh/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/seo-audit/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/keyword-research/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/content-gap/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/backlinks/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/report/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/trending/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/link-check/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/paa/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/og-image/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/topic-cluster/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/competitor/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/translate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/vitals/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/blog/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/blog/index-now",
      "schedule": "0 0 * * 0"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.getmova.my.id" }],
      "destination": "https://getmova.my.id/:path*",
      "permanent": true
    },
    {
      "source": "/youtube-downloader",
      "destination": "https://getmova.my.id",
      "permanent": true
    },
    {
      "source": "/youtube-mp3",
      "destination": "https://getmova.my.id",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://getmova.my.id" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Range" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Range, Content-Length, Content-Disposition" }
      ]
    }
  ],
  "trailingSlash": false
}
